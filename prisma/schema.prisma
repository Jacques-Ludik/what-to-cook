// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    url      = env("DATABASE_URL")
}

model Post {
    id        Int      @id @default(autoincrement())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    createdBy   User   @relation(fields: [createdById], references: [id])
    createdById String

    @@index([name])
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    role          String?
    accounts      Account[]
    sessions      Session[]
    posts         Post[]
    dietType      DietType? @relation(fields: [dietTypeId], references: [id])
    dietTypeId    Int?
    favourites   UserRecipes[]
    interests    UserRecipeInterests[]
    ingredients     UserIngredients[]
    UserAllergens UserAllergens[]
    estimatedTime Int?
    strictSearch  Boolean? @default(false)
    highProtein   Boolean? @default(false)
    lowCalorie    Boolean? @default(false)
    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model Ingredient {
    id        Int      @id @default(autoincrement())
    name      String
    recipe  RecipeIngredients[]
    user    UserIngredients[]

    // Each ingredient now belongs to ONE group
   ingredientGroupId Int?
   ingredientGroup   IngredientGroup? @relation(fields: [ingredientGroupId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// NEW MODEL: A group for similar ingredients
model IngredientGroup {
  id    Int     @id @default(autoincrement())
  name  String  @unique // e.g., "Fats", "Flour Types", "Onions"
  
  // A group can have many ingredients
  ingredients Ingredient[]
}

model Recipe {
    id        Int      @id @default(autoincrement())
    title      String
    imageUrl  String?
    link      String?
    category  String?
    area      String?
    source    String?  //from where I got the data (e.g. FatSecret)
    recipeDescription    String?
    dietType  DietType? @relation(fields: [dietTypeId], references: [id])
    dietTypeId Int?
    allergens   RecipeAllergens[]
    ingredients  RecipeIngredients[]
    instructions String?
    prepTime  Int?
    estimatedTime Int?
    protein Int?
    fat     Int?
    carb    Int?
    calorie Int?
    microNutrients  String?
    user    UserRecipes[]
    usersInterested UserRecipeInterests[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model RecipeIngredients {
    id          Int       @id @default(autoincrement())
    recipeId    Int
    ingredientId Int
    measure     String?
    recipe      Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
    ingredient  Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    //@@unique([recipeId, ingredientId])
}

model DietType {
    id        Int      @id @default(autoincrement())
    name      String
    Recipe Recipe[]
    User User[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model UserRecipes {
    userId    String
    recipeId  Int
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())
    @@id([userId, recipeId])
}

model UserRecipeInterests {
    userId    String
    recipeId  Int
    counter   Int
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())
    @@id([userId, recipeId])
}
model UserIngredients {
    userId      String
    ingredientId Int
    counter        Int
    user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    ingredient  Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    @@id([userId, ingredientId])
}

model Allergens {
    id        Int      @id @default(autoincrement())
    name      String
    user UserAllergens[]
    recipe RecipeAllergens[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model UserAllergens {
    userId      String
    allergenId  Int
    user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    allergen    Allergens  @relation(fields: [allergenId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())
    @@id([userId, allergenId])
}

model RecipeAllergens {
    id          Int       @id @default(autoincrement())
    recipeId    Int
    allergenId  Int
    recipe      Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
    allergen    Allergens @relation(fields: [allergenId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())
    @@unique([recipeId, allergenId])
}

